# Copiar a .env.local (nunca commitear .env.local) y rellenar con los
# valores reales del proyecto Supabase `human` (Family Hub vive en el
# schema `family_hub` de este proyecto — ver ADR 0007, no en un proyecto
# propio).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# La service_role key NUNCA va aquí ni en ningún archivo del repositorio.
# Solo se usa en entornos de servidor gestionados fuera del repo (ej. variables
# de entorno del hosting), nunca expuesta al cliente.

# IMPORTANTE (pasos manuales únicos, ver ADR 0007):
# 1. El schema `family_hub` debe estar añadido en Project Settings > API >
#    "Exposed schemas" del proyecto `human`, o la app no podrá hacer ninguna
#    consulta.
# 2. La URL de callback de esta app (<origin>/auth/callback) debe estar en
#    Authentication > URL Configuration > "Redirect URLs" del proyecto `human`.

